 0\n    assert ps.backlog == 0\n\ndef test_fulfill_orders_shortage(active_state):\n    \"\"\"demand > inventory → backlog accumulates.\"\"\"\n    active_state.players[PlayerRole.RETAILER].inventory = 4\n    active_state.players[PlayerRole.RETAILER].backlog = 0\n    result = fulfill_orders(active_state, customer_demand=10)\n    ps = result.players[PlayerRole.RETAILER]\n    assert ps.inventory == 0\n    assert ps.backlog == 6\n\ndef test_fulfill_orders_backlog_included(active_state):\n    \"\"\"Existing backlog + new demand both fulfilled if inventory allows.\"\"\"\n    active_state.players[PlayerRole.RETAILER].inventory = 20\n    active_state.players[PlayerRole.RETAILER].backlog = 5\n    result = fulfill_orders(active_state, customer_demand=3)\n    ps = result.players[PlayerRole.RETAILER]\n    assert ps.inventory == 12  # 20 - 5 - 3\n    assert ps.backlog == 0\n\ndef test_fulfill_orders_zero_demand(active_state):\n    \"\"\"customer_demand=0 → inventory unchanged, backlog cleared if stocked.\"\"\"\n    active_state.players[PlayerRole.RETAILER].inventory = 10\n    active_state.players[PlayerRole.RETAILER].backlog = 0\n    result = fulfill_orders(active_state, customer_demand=0)\n    assert result.players[PlayerRole.RETAILER].inventory == 10\n\ndef test_place_orders_propagates_upstream(active_state):\n    \"\"\"Retailer order shows up in Wholesaler incoming_orders.\"\"\"\n    active_state.orders_this_round[PlayerRole.RETAILER] = 6\n    before_len = len(active_state.players[PlayerRole.WHOLESALER].incoming_orders)\n    result = place_orders(active_state)\n    assert len(result.players[PlayerRole.WHOLESALER].incoming_orders) == before_len + 1\n\ndef test_place_orders_factory_schedules_production(active_state):\n    \"\"\"Factory order creates IncomingShipment (no upstream to push to).\"\"\"\n    active_state.orders_this_round[PlayerRole.FACTORY] = 8\n    before = len(active_state.players[PlayerRole.FACTORY].incoming_shipments)\n    result = place_orders(active_state)\n    assert len(result.players[PlayerRole.FACTORY].incoming_shipments) > before\n\ndef test_place_orders_records_last_order(active_state):\n    \"\"\"last_order field updated after place_orders.\"\"\"\n    active_state.orders_this_round[PlayerRole.RETAILER] = 7\n    result = place_orders(active_state)\n    assert result.players[PlayerRole.RETAILER].last_order == 7\n\ndef test_accrue_costs_formula(active_state):\n    \"\"\"Cost = inventory * holding_cost + backlog * backlog_cost.\"\"\"\n    cfg = active_state.config\n    role = PlayerRole.RETAILER\n    active_state.players[role].inventory = 10\n    active_state.players[role].backlog = 2\n    active_state.players[role].cumulative_cost = 0.0\n    result = accrue_costs(active_state)\n    expected = 10 * cfg.holding_cost + 2 * cfg.backlog_cost\n    assert result.players[role].cumulative_cost == pytest.approx(expected)\n\ndef test_accrue_costs_accumulates(active_state):\n    \"\"\"cumulative_cost grows each round.\"\"\"\n    active_state.players[PlayerRole.RETAILER].inventory = 5\n    active_state.players[PlayerRole.RETAILER].cumulative_cost = 10.0\n    r1 = accrue_costs(active_state)\n    r2 = accrue_costs(r1)\n    assert r2.players[PlayerRole.RETAILER].cumulative_cost > r1.players[PlayerRole.RETAILER].cumulative_cost\n\ndef test_accrue_costs_zero_holding(active_state):\n    \"\"\"No inventory, no backlog → cumulative_cost unchanged.\"\"\"\n    role = PlayerRole.RETAILER\n    active_state.players[role].inventory = 0\n    active_state.players[role].backlog = 0\n    active_state.players[role].cumulative_cost = 5.0\n    result = accrue_costs(active_state)\n    assert result.players[role].cumulative_cost == 5.0\n```\n\n---\n\n### HIGH: `models/order.py` — 0 tests\n\n```python\n# tests/core/test_models.py — add these\n\ndef test_order_requires_nonnegative_quantity():\n    with pytest.raises(ValidationError):\n        Order(quantity=-1, from_role=PlayerRole.RETAILER,\n              to_role=PlayerRole.WHOLESALER, delivery_round=1)\