FROM python:3.12-slim
WORKDIR /app
COPY variants/realtime/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY core/ ./core/
COPY variants/realtime/ ./variants/realtime/
ENV PYTHONPATH=/app
CMD ["uvicorn", "variants.realtime.main:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]
