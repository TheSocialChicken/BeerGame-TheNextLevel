        "content": "import pytest\nfrom core.engine.game_engine import GameEngine\nfrom core.models import GameConfig, GamePhase, PlayerRole, ROLE_ORDER\n\n@pytest.fixture\ndef engine():\n    return GameEngine()\n\ndef test_submit_order_after_game_finished(engine):\n    config = GameConfig(num_rounds=1)\n    state = engine.create_game(config, ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    from core.ai_players.rule_based import ConstantOrderAI\n    for role in PlayerRole:\n        state = engine.submit_order(state, role, ConstantOrderAI(role).decide_order(state))\n    state = engine.process_round(state)\n    assert state.phase == GamePhase.FINISHED\n    with pytest.raises(ValueError):\n        engine.submit_order(state, PlayerRole.RETAILER, 4)\n\ndef test_process_round_on_waiting_game(engine):\n    state = engine.create_game()\n    assert state.phase == GamePhase.WAITING\n    with pytest.raises((ValueError, AssertionError)):\n        engine.process_round(state)\n\ndef test_demand_pattern_wraps_modulo(engine):\n    config = GameConfig(num_rounds=3, demand_pattern=[2, 8])\n    state = engine.create_game(config, ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    from core.ai_players.rule_based import ConstantOrderAI\n    for _ in range(3):\n        for role in PlayerRole:\n            state = engine.submit_order(state, role, ConstantOrderAI(role).decide_order(state))\n        state = engine.process_round(state)\n    assert state.customer_demand_history == [2, 8, 2]\n\ndef test_get_visible_state_upstream_data_hidden(engine):\n    state = engine.create_game(ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    visible = engine.get_visible_state(state, PlayerRole.RETAILER)\n    # Retailer must NOT see wholesaler/distributor/factory inventory\n    assert \"players\" not in visible\n\ndef test_get_visible_state_all_roles(engine):\n    state = engine.create_game(ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    for role in PlayerRole:\n        visible = engine.get_visible_state(state, role)\n        assert visible[\"role\"] == role\n        assert \"inventory\" in visible\n\ndef test_game_config_min_rounds(engine):\n    state = engine.create_game(GameConfig(num_rounds=1), ai_roles=set(PlayerRole))\n    assert state.config.num_rounds == 1\n\ndef test_game_config_max_rounds(engine):\n    state = engine.create_game(GameConfig(num_rounds=100), ai_roles=set(PlayerRole))\n    assert state.config.num_rounds == 100\n\ndef test_multiple_order_submissions_same_role_last_wins(engine):\n    state = engine.create_game(ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    state = engine.submit_order(state, PlayerRole.RETAILER, 3)\n    state = engine.submit_order(state, PlayerRole.RETAILER, 9)\n    assert state.orders_this_round[PlayerRole.RETAILER] == 9\n```\n\n---\n\n```python\n",
