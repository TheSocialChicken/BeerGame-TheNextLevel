{
  "name": "research-agent",
  "nodes": [
    {
      "id": "n1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "path": "research-webhook",
        "httpMethod": "POST",
        "responseMode": "onReceived"
      },
      "webhookId": "research-webhook"
    },
    {
      "id": "n2",
      "name": "Extract issue context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        300
      ],
      "parameters": {
        "jsCode": "\nconst body = $input.first().json.body || $input.first().json;\nconst issue = body.issue || {};\nconst hasLabel = (issue.labels || []).some(l => l.name === 'pipeline: research');\nif (!hasLabel) return [];\nreturn [{ json: { issue_number: issue.number, title: issue.title, body: issue.body, repo: body.repository?.full_name } }];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "n3",
      "name": "Call Ollama for research",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        300
      ],
      "parameters": {
        "url": "http://100.95.236.57:11434/api/generate",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer "
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "llama3.1:8b"
            },
            {
              "name": "prompt",
              "value": "=Research this topic for a Beer Game supply chain simulation project and provide a concise summary with key findings:\\n\\nTitle: {{ $json.title }}\\n\\n{{ $json.body }}"
            },
            {
              "name": "stream",
              "value": "false"
            }
          ]
        }
      }
    },
    {
      "id": "n4",
      "name": "Format findings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        300
      ],
      "parameters": {
        "jsCode": "\nconst research = JSON.parse($input.first().json.response || '{}');\nconst findings = research.response || $input.first().json.response || 'No findings';\nconst issueCtx = $('Extract issue context').first().json;\nreturn [{ json: { ...issueCtx, findings, comment: `## \ud83d\udd2c Research Findings\\n\\n${findings}\\n\\n_Generated by research-agent using Ollama llama3.1:8b_` } }];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "n5",
      "name": "Post findings as comment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1280,
        300
      ],
      "parameters": {
        "url": "=https://api.github.com/repos/{{ $json.repo }}/issues/{{ $json.issue_number }}/comments",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer "
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={{ $json.comment }}"
            }
          ]
        }
      }
    },
    {
      "id": "n6",
      "name": "Add planning label",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        300
      ],
      "parameters": {
        "url": "=https://api.github.com/repos/{{ $('Extract issue context').first().json.repo }}/issues/{{ $('Extract issue context').first().json.issue_number }}/labels",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer "
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "labels",
              "value": "[\"pipeline: planning\"]"
            }
          ]
        }
      }
    }
  ],
