        "code": "import pytest\nfrom backend.services.game_store import InMemoryGameStore\nfrom core.models import GameState, GameConfig\n\n\ndef make_state(game_id: str) -> GameState:\n    from core.engine.game_engine import GameEngine\n    return GameEngine().create_game(GameConfig(), game_id=game_id)\n\n\n@pytest.fixture\ndef store():\n    return InMemoryGameStore()\n\n\nasync def test_get_missing_returns_none(store):\n    assert await store.get(\"nope\") is None\n\n\nasync def test_save_and_get_roundtrip(store):\n    state = make_state(\"g1\")\n    await store.save(state)\n    retrieved = await store.get(\"g1\")\n    assert retrieved is not None\n    assert retrieved.game_id == \"g1\"\n\n\nasync def test_delete_removes_game(store):\n    state = make_state(\"g1\")\n    await store.save(state)\n    await store.delete(\"g1\")\n    assert await store.get(\"g1\") is None\n\n\nasync def test_delete_nonexistent_is_noop(store):\n    await store.delete(\"never-existed\")\n\n\nasync def test_list_ids_empty(store):\n    assert await store.list_ids() == []\n\n\nasync def test_list_ids_returns_all(store):\n    for gid in [\"a\", \"b\", \"c\"]:\n        await store.save(make_state(gid))\n    ids = await store.list_ids()\n    assert set(ids) == {\"a\", \"b\", \"c\"}\n\n\nasync def test_save_overwrites_existing(store):\n    state = make_state(\"g1\")\n    await store.save(state)\n    state2 = make_state(\"g1\")\n    await store.save(state2)\n    ids = await store.list_ids()\n    assert ids.count(\"g1\") == 1"
