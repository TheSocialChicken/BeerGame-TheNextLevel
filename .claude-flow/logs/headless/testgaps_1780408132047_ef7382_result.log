ers[PlayerRole.RETAILER]\n    retailer.inventory = 20\n    retailer.backlog = 5\n    state = fulfill_orders(state, customer_demand=4)\n    # demand = 4 + 5 backlog = 9, shipped=9, backlog=0, inventory=11\n    assert state.players[PlayerRole.RETAILER].backlog == 0\n    assert state.players[PlayerRole.RETAILER].inventory == 11\n\n\ndef test_fulfill_orders_ships_to_downstream(base_state):\n    state = base_state\n    state.orders_this_round = {PlayerRole.RETAILER: 6, PlayerRole.WHOLESALER: 6,\n                                PlayerRole.DISTRIBUTOR: 6, PlayerRole.FACTORY: 6}\n    wholesaler = state.players[PlayerRole.WHOLESALER]\n    wholesaler.inventory = 20\n    state = fulfill_orders(state, customer_demand=4)\n    # Retailer's incoming_shipments should gain a new entry from wholesaler\n    retailer_incoming = state.players[PlayerRole.RETAILER].incoming_shipments\n    # At least one shipment toward retailer exists\n    assert any(s.quantity > 0 for s in retailer_incoming)\n\n\ndef test_fulfill_orders_zero_demand(base_state):\n    state = base_state\n    state.orders_this_round = {role: 0 for role in PlayerRole}\n    before = state.players[PlayerRole.RETAILER].inventory\n    state = fulfill_orders(state, customer_demand=0)\n    assert state.players[PlayerRole.RETAILER].inventory == before\n    assert state.players[PlayerRole.RETAILER].backlog == 0\n```\n\n---\n\n### 4. `place_orders` — factory production path untested directly\n\n```python\ndef test_place_orders_factory_schedules_production(base_state):\n    state = base_state\n    state.orders_this_round = {role: 0 for role in PlayerRole}\n    state.orders_this_round[PlayerRole.FACTORY] = 8\n    before_len = len(state.players[PlayerRole.FACTORY].incoming_shipments)\n    state = place_orders(state)\n    after_len = len(state.players[PlayerRole.FACTORY].incoming_shipments)\n    assert after_len == before_len + 1\n    new_shipment = state.players[PlayerRole.FACTORY].incoming_shipments[-1]\n    assert new_shipment.quantit