        "content": "\n---\n\n**4. Add to `tests/backend/test_api.py`**\n\n```python\nasync def test_submit_order_game_already_finished(client, active_game_id):\n    \"\"\"Orders after game_over should return 400.\"\"\"\n    # Advance to finished state by completing all rounds\n    # (adjust num_rounds=1 in config for speed)\n    ...\n\nasync def test_get_state_invalid_role(client, active_game_id):\n    resp = await client.get(f\"/games/{active_game_id}/state?role=invalid\")\n    assert resp.status_code == 422\n\nasync def test_list_games_empty(client):\n    resp = await client.get(\"/games/\")\n    assert resp.status_code == 200\n    assert resp.json()[\"game_ids\"] == []\n\nasync def test_submit_order_duplicate_role(client, active_game_id):\n    \"\"\"Same role ordering twice in one round should return 400.\"\"\"\n    await client.post(\n        f\"/games/{active_game_id}/orders\",\n        json={\"role\": \"retailer\", \"quantity\": 4},\n    )\n    resp = await client.post(\n        f\"/games/{active_game_id}/orders\",\n        json={\"role\": \"retailer\", \"quantity\": 4},\n    )\n    assert resp.status_code == 400\n```\n\n---\n\n**5. Add to `tests/core/test_engine.py`**\n\n```python\ndef test_get_visible_state_invalid_role_raises(engine, active_state):\n    from core.models import PlayerRole\n    # PlayerRole.FACTORY exists but if we pass a role not in players dict:\n    with pytest.raises((KeyError, ValueError)):\n        engine.get_visible_state(active_state, \"nonexistent_role\")\n\ndef test_submit_order_waiting_game_raises(engine):\n    from core.engine.game_engine import GameEngine\n    from core.models import GameConfig, PlayerRole\n    state = GameEngine().create_game(GameConfig())\n    with pytest.raises(ValueError, match=\"not active\"):\n        engine.submit_order(state, PlayerRole.RETAILER, 4)\n\ndef test_process_round_not_complete_raises(engine, active_state):\n    # Only one player has ordered — round not complete\n    from core.models import PlayerRole\n    active_state = engine.submit_order(active_state, PlayerRole.RETAILER, 4)\n    with pytest.raises(ValueError, match=\"not complete\"):\n        engine.process_round(active_state)\n```\n\n---\n\n**6. Add to `tests/core/test_models.py`**\n\n```python\ndef test_game_config_num_rounds_boundary():\n    from core.models import GameConfig\n    import pytest\n    from pydantic import ValidationError\n    cfg = GameConfig(num_rounds=1)\n    assert cfg.num_rounds == 1\n    with pytest.raises(ValidationError):\n        GameConfig(num_rounds=0)\n\ndef test_game_config_negative_costs_rejected():\n    from core.models import GameConfig\n    import pytest\n    from pydantic import ValidationError\n    with pytest.raises(ValidationError):\n        GameConfig(holding_cost=-1)\n\ndef test_player_state_round_cost_zero_inventory():\n    from core.models import PlayerState\n    ps = PlayerState(inventory=0, backlog=0)\n    assert ps.round_cost(holding_cost=0.5, backlog_cost=1.0) == 0.0\n\ndef test_game_state_is_round_complete_empty_players():\n    from core.models import GameState, GameConfig\n    state = GameState(game_id=\"x\", config=GameConfig(), players={}, orders_this_round={})\n    # Empty players — should be considered complete (or raise; document the contract)\n    result = state.is_round_complete()\n    assert isinstance(result, bool)\n```\n\n---\n\n**7. Add to `tests/core/test_ai_players.py`**\n\n```python\ndef test_constant_order_ai_zero_quantity(active_state):\n    from core.ai_players.rule_based import ConstantOrderAI\n    from core.models import PlayerRole\n    ai = ConstantOrderAI(PlayerRole.RETAILER, quantity=0)\n    assert ai.decide_order(active_state) == 0\n\ndef test_constant_order_ai_negative_quantity_rejected(active_state):\n    from core.ai_players.rule_based import ConstantOrderAI\n    from core.models import PlayerRole\n    import pytest\n    with pytest.raises(ValueError):\n        ConstantOrderAI(PlayerRole.RETAILER, quantity=-5)\n\ndef test_order_up_to_ai_high_pipeline_orders_zero(active_state):\n    \"\"\"When pipeline already exceeds target, AI should not over-order.\"\"\"\n    from core.ai_players.rule_based import OrderUpToAI\n    from core.models import PlayerRole\n    # Set pipeline to a huge value\n    active_state.players[PlayerRole.RETAILER].incoming_shipments = [100, 100, 100]\n    ai = OrderUpToAI(PlayerRole.RETAILER)\n    order = ai.decide_order(active_state)\n    assert order >= 0  # Never negative\n\ndef test_base_ai_player_cannot_instantiate():\n    from core.ai_players.base import BaseAIPlayer\n    import pytest\n    with pytest.raises(TypeError):\n        BaseAIPlayer(role=\"retailer\")\n```\n\n---\n\n**8. Add to `tests/core/test_engine.py` — multi-round integration**\n\n```python\nasync def test_full_game_cost_accumulates(engine):\n    \"\"\"Run a complete 1-round game, verify costs > 0.\"\"\"\n    from core.models import GameConfig, PlayerRole\n    config = GameConfig(num_rounds=1)\n    state = engine.create_game(config)\n    state = engine.start_game(state)\n    for role in PlayerRole:\n        state = engine.submit_order(state, role, 4)\n    state = engine.process_round(state)\n    assert state.total_cost() > 0\n\nasync def test_backlog_accumulates_when_inventory_zero(engine):\n    \"\"\"Factory gets no replenishment → upstream roles accumulate backlog.\"\"\"\n    from core.models import GameConfig, PlayerRole\n    config = GameConfig(num_rounds=3)\n    state = engine.create_game(config)\n    state = engine.start_game(state)\n    # Order 0 every round — should build backlog\n    for _ in range(3):\n        for role in PlayerRole:\n            state = engine.submit_order(state, role, 0)\n        state = engine.process_round(state)\n    retailer = state.players[PlayerRole.RETAILER]\n    assert retailer.backlog > 0\n```\n\n---\n\n",
