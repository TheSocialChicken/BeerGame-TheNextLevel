    {
      "id": "n2",
      "name": "Extract push context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        300
      ],
      "parameters": {
        "jsCode": "\nconst body = $input.first().json.body || $input.first().json;\nif (!body.ref) return [];\nreturn [{ json: { ref: body.ref, sha: body.after, repo: body.repository?.full_name, pusher: body.pusher?.name } }];\n",
        "mode": "runOnceForAllItems"
      }
    },
    {
      "id": "n3",
      "name": "Trigger GitHub Actions CI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        300
      ],
      "parameters": {
        "url": "=https://api.github.com/repos/{{ $json.repo }}/actions/workflows/ci.yml/dispatches",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer "
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "ref",
              "value": "={{ $json.ref }}"
            }
          ]
        }
      }
    }
