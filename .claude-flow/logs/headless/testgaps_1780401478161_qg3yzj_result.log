nd():\n    state = make_state()\n    state.players[PlayerRole.RETAILER].incoming_shipments = [\n        IncomingShipment(quantity=2, arrives_in_rounds=1),\n        IncomingShipment(quantity=3, arrives_in_rounds=1),\n    ]\n    before = state.players[PlayerRole.RETAILER].inventory\n    state = advance_shipments(state)\n    assert state.players[PlayerRole.RETAILER].inventory == before + 5\n\n# ─── fulfill_orders ───────────────────────────────────────────────────────────\n\ndef test_fulfill_orders_demand_exceeds_inventory():\n    state = make_state(initial_inventory=2)\n    state.orders_this_round = {r: 0 for r in PlayerRole}\n    state = fulfill_orders(state, customer_demand=10)\n    retailer = state.players[PlayerRole.RETAILER]\n    assert retailer.inventory == 0\n    assert retailer.backlog == 8  # 10 demand - 2 shipped\n\ndef test_fulfill_orders_zero_demand_no_backlog():\n    state = make_state(initial_inventory=12)\n    state.orders_this_round = {r: 0 for r in PlayerRole}\n    state = fulfill_orders(state, customer_demand=0)\n    retailer = state.players[PlayerRole.RETAILER]\n    assert retailer.backlog == 0\n    assert retailer.inventory == 12\n\ndef test_fulfill_orders_backlog_carried_and_cleared():\n    state = make_state(initial_inventory=5)\n    state.players[PlayerRole.RETAILER].backlog = 3  # existing backlog\n    state.orders_this_round = {r: 0 for r in PlayerRole}\n    state = fulfill_orders(state, customer_demand=0)\n    retailer = state.players[PlayerRole.RETAILER]\n    # 0 new demand + 3 backlog; 5 inventory → ships 3, backlog = 0\n    assert retailer.backlog == 0\n    assert retailer.inventory == 2\n\ndef test_fulfill_orders_ships_to_downstream():\n    state = make_state(initial_inventory=10)\n    state.orders_this_round = {PlayerRole.RETAILER: 4, PlayerRole.WHOLESALER: 0,\n                               PlayerRole.DISTRIBUTOR: 0, PlayerRole.FACTORY: 0}\n    before_shipments = len(state.players[PlayerRole.RETAILER].incoming_shipments)\n    state = fulfill_orders(state, customer_demand=4)\n    # Wholesaler ships to Retailer pipeline\n    assert len(state.players[PlayerRole.RETAILER].incoming_shipments) > before_shipments\n\n# ─── place_orders ─────────────────────────────────────────────────────────────\n\ndef test_place_orders_factory_schedules_own_production():\n    state = make_state(order_delay=2)\n    state.orders_this_round = {r: 5 for r in PlayerRole}\n    before_shipments = len(state.players[PlayerRole.FACTORY].incoming_shipments)\n    state = place_orders(state)\n    factory = state.players[PlayerRole.FACTORY]\n    new_shipments = factory.incoming_shipments[before_shipments:]\n    assert any(s.quantity == 5 and s.arrives_in_rounds == 2 for s in new_shipments)\n\ndef test_place_orders_non_factory_passes_to_upstream():\n    state = make_state()\n    state.orders_this_round = {r: 3 for r in PlayerRole}\n    before = len(state.players[PlayerRole.WHOLESALER].incoming_orders)\n    state = place_orders(state)\n    assert len(state.players[PlayerRole.WHOLESALER].incoming_orders) > before\n\ndef test_place_orders_records_last_order():\n    state = make_state()\n    state.orders_this_round = {r: 7 for r in PlayerRole}\n    state = place_orders(state)\n    for ps in state.players.values():\n        assert ps.last_order == 7\n\ndef test_place_orders_zero_orders():\n    state = make_state()\n    state.orders_this_round = {r: 0 for r in PlayerRole}\n    state = place_orders(state)\n    factory = state.players[PlayerRole.FACTORY]\n    assert factory.incoming_shipments[-1].quantity == 0\n\n# ─── accrue_costs ─────────────────────────────────────────────────────────────\n\ndef test_accrue_costs_holding():\n    state = make_state(initial_inventory=10, holding_cost=2, backlog_cost=4)\n    for ps in state.players.values():\n        ps.cumulative_cost = 0\n    state = accrue_costs(state)\n    for ps in state.players.values():\n        assert ps.cumulative_cost == 20  # 10 * 2\n\ndef test_accrue_costs_backlog():\n    state = make_state(initial_inventory=0, holding_cost=1, backlog_cost=3)\n    for ps in state.players.values():\n        ps.inventory = 0\n        ps.backlog = 4\n        ps.cumulative_cost = 0\n    state = accrue_costs(state)\n    for ps in state.players.values():\n        assert ps.cumulative_cost == 12  # 4 * 3\n\ndef test_accrue_costs_cumulative():\n    state = make_state(initial_inventory=5, holding_cost=1, backlog_cost=1)\n    for ps in state.players.values():\n        ps.cumulative_cost = 100\n    state = accrue_costs(state)\n    for ps in state.players.values():\n        assert ps.cumulative_cost > 100\n```\n\n---\n\n```python\n# tests/core/test_models_order.py\nimport pytest\nfrom pydantic import ValidationError\nfrom core.models.order import Order, IncomingShipment\nfrom core.models.player import PlayerRole\n\ndef test_order_valid():\n    o = Order(quantity=5, from_role=PlayerRole.RETAILER,\n               to_role=PlayerRole.WHOLESALER, delivery_round=3)\n    assert o.quantity == 5\n\ndef test_order_zero_quantity_allowed():\n    o = Order(quantity=0, from_role=PlayerRole.RETAILER,\n               to_role=PlayerRole.WHOLESALER, delivery_round=1)\n    assert o.quantity == 0\n\ndef test_order_negative_quantity_rejected():\n    with pytest.raises(ValidationError):\n        Order(quantity=-1, from_role=PlayerRole.RETAILER,\n              to_role=PlayerRole.WHOLESALER, delivery_round=1)\n\ndef test_order_to_role_none_allowed():\n    o = Order(quantity=4, from_role=PlayerRole.FACTORY, to_role=None, delivery_round=2)\n    assert o.to_role is None\n\ndef test_incoming_shipment_valid():\n    s = IncomingShipment(quantity=3, arrives_in_rounds=2)\n    assert s.arrives_in_rounds == 2\n\ndef test_incoming_shipment_zero_arrives():\n    # arrives_in_rounds=0 is valid per Field(ge=0) — verify behavior\n    s = IncomingShipment(quantity=5, arrives_in_rounds=0)\n    assert s.arrives_in_rounds == 0\n\ndef test_incoming_shipment_negative_quantity_rejected():\n    with pytest.raises(ValidationError):\n        IncomingShipment(quantity=-1, arrives_in_rounds=1)\n\ndef test_incoming_shipment_negative_rounds_rejected():\n    with pytest.raises(ValidationError):\n        IncomingShipment(quantity=3, arrives_in_rounds=-1)\n```\n\n---\n\n```python\n# tests/core/test_models_player.py\nfrom core.models.player import PlayerRole, ROLE_ORDER\n\ndef test_role_order_has_four_roles():\n    assert len(ROLE_ORDER) == 4\n\ndef test_role_order_sequence():\n    assert ROLE_ORDER[0] == PlayerRole.RETAILER\n    assert ROLE_ORDER[-1] == PlayerRole.FACTORY\n\ndef test_role_order_no_duplicates():\n    assert len(set(ROLE_ORDER)) == len(ROLE_ORDER)\n\ndef test_all_roles_in_role_order():\n    assert set(ROLE_ORDER) == set(PlayerRole)\n\ndef test_player_role_values():\n    assert PlayerRole.RETAILER.value == \"retailer\"\n    assert PlayerRole.FACTORY.value == \"factory\"\n```\n\n---\n\n```python\n# tests/core/test_engine_gaps.py\nimport pytest\nfrom core.engine.game_engine import GameEngine\nfrom core.models import GameConfig, GamePhase, PlayerRole, ROLE_ORDER\n\n@pytest.fixture\ndef engine():\n    return GameEngine()\n\ndef test_submit_order_after_game_finished(engine):\n    config = GameConfig(num_rounds=1)\n    state = engine.create_game(config, ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    from core.ai_players.rule_based import ConstantOrderAI\n    for role in PlayerRole:\n        state = engine.submit_order(state, role, ConstantOrderAI(role).decide_order(state))\n    state = engine.process_round(state)\n    assert state.phase == GamePhase.FINISHED\n    with pytest.raises(ValueError):\n        engine.submit_order(state, PlayerRole.RETAILER, 4)\n\ndef test_process_round_on_waiting_game(engine):\n    state = engine.create_game()\n    assert state.phase == GamePhase.WAITING\n    with pytest.raises((ValueError, AssertionError)):\n        engine.process_round(state)\n\ndef test_demand_pattern_wraps_modulo(engine):\n    config = GameConfig(num_rounds=3, demand_pattern=[2, 8])\n    state = engine.create_game(config, ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    from core.ai_players.rule_based import ConstantOrderAI\n    for _ in range(3):\n        for role in PlayerRole:\n            state = engine.submit_order(state, role, ConstantOrderAI(role).decide_order(state))\n        state = engine.process_round(state)\n    assert state.customer_demand_history == [2, 8, 2]\n\ndef test_get_visible_state_upstream_data_hidden(engine):\n    state = engine.create_game(ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    visible = engine.get_visible_state(state, PlayerRole.RETAILER)\n    # Retailer must NOT see wholesaler/distributor/factory inventory\n    assert \"players\" not in visible\n\ndef test_get_visible_state_all_roles(engine):\n    state = engine.create_game(ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    for role in PlayerRole:\n        visible = engine.get_visible_state(state, role)\n        assert visible[\"role\"] == role\n        assert \"inventory\" in visible\n\ndef test_game_config_min_rounds(engine):\n    state = engine.create_game(GameConfig(num_rounds=1), ai_roles=set(PlayerRole))\n    assert state.config.num_rounds == 1\n\ndef test_game_config_max_rounds(engine):\n    state = engine.create_game(GameConfig(num_rounds=100), ai_roles=set(PlayerRole))\n    assert state.config.num_rounds == 100\n\ndef test_multiple_order_submissions_same_role_last_wins(engine):\n    state = engine.create_game(ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    state = engine.submit_order(state, PlayerRole.RETAILER, 3)\n    state = engine.submit_order(state, PlayerRole.RETAILER, 9)\n    assert state.orders_this_round[PlayerRole.RETAILER] == 9\n```\n\n---\n\n```python\n# tests/api/test_endpoints.py  — SKELETON (needs FastAPI app import)\n# Create tests/api/__init__.py too.\n\nimport pytest\nfrom httpx import AsyncClient, ASGITransport\n\n# from main import app  ← replace with your actual app entry point\n\n@pytest.fixture\nasync def client():\n    async with AsyncClient(transport=ASGITransport(app=app), base_url=\"http://test\") as c:\n        yield c\n\n@pytest.mark.asyncio\nasync def test_create_game_returns_game_id(client):\n    resp = await client.post(\"/games\", json={})\n    assert resp.status_code == 201\n    assert \"game_id\" in resp.json()\n\n@pytest.mark.asyncio\nasync def test_submit_order_returns_updated_state(client):\n    create = await client.post(\"/games\", json={})\n    game_id = create.json()[\"game_id\"]\n    resp = await client.post(f\"/games/{game_id}/orders\",\n                              json={\"role\": \"retailer\", \"quantity\": 4})\n    assert resp.status_code == 200\n\n@pytest.mark.asyncio\nasync def test_submit_order_on_missing_game_returns_404(client):\n    resp = await client.post(\"/games/nonexistent/orders\",\n                              json={\"role\": \"retailer\", \"quantity\": 4})\n    assert resp.status_code == 404\n\n@pytest.mark.asyncio\nasync def test_submit_negative_order_returns_422(client):\n    create = await client.post(\"/games\", json={})\n    game_id = create.json()[\"game_id\"]\n    resp = await client.post(f\"/games/{game_id}/orders\",\n                              json={\"role\": \"retailer\", \"quantity\": -1})\n    assert resp.status_code == 422\n```\n\n---\n\n## Priority order to implement\n\n| # | File | Why |\n|---|------|-----|\n| 1 | `tests/core/test_order_processor.py` | Zero unit tests; core engine correctness |\n| 2 | `tests/core/test_models_order.py` | Validation boundary contracts |\n| 3 | `tests/core/test_engine_gaps.py` | Edge cases in existing engine tests |\n| 4 | `tests/core/test_models_player.py` | ROLE_ORDER ordering is game-logic critical |\n| 5 | `tests/api/test_endpoints.py` | Integration — needs app entry point first |\n\n`test_demand_pattern_wraps_modulo` and `test_submit_order_after_game_finished` are most likely to find real bugs. 