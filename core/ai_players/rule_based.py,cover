> from core.models import GameState, PlayerRole
> from .base import BaseAIPlayer
  
> TARGET_INVENTORY = 12
> SAFETY_STOCK = 4
  
  
> class OrderUpToAI(BaseAIPlayer):
>     """
>     Classic order-up-to policy: order enough to bring
>     inventory + pipeline up to a target level.
>     """
  
>     def decide_order(self, state: GameState) -> int:
>         ps = state.players[self.role]
>         pipeline = sum(s.quantity for s in ps.incoming_shipments)
>         position = ps.inventory - ps.backlog + pipeline
>         target = TARGET_INVENTORY + SAFETY_STOCK
>         order = max(0, target - position)
>         return order
  
  
> class ConstantOrderAI(BaseAIPlayer):
>     """Orders a fixed quantity every round — naive baseline."""
  
>     def __init__(self, role: PlayerRole, quantity: int = 4):
>         super().__init__(role)
>         self.quantity = quantity
  
>     def decide_order(self, state: GameState) -> int:
>         return self.quantity
