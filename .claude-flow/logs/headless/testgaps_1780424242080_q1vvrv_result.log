        "code": "import pytest\nfrom httpx import AsyncClient, ASGITransport\nfrom httpx_ws import aconnect_ws  # or use starlette.testclient.WebSocketTestSession\nfrom backend.main import app\nfrom backend.services.game_store import game_store\n\n\n@pytest.fixture(autouse=True)\nasync def clear_store():\n    for gid in await game_store.list_ids():\n        await game_store.delete(gid)\n    yield\n    for gid in await game_store.list_ids():\n        await game_store.delete(gid)\n\n\n@pytest.fixture\nasync def active_game_id():\n    async with AsyncClient(transport=ASGITransport(app=app), base_url=\"http://test\") as c:\n        resp = await c.post(\"/games/\", json={})\n        gid = resp.json()[\"game_id\"]\n        await c.post(f\"/games/{gid}/start\")\n    return gid\n\n\n# --- Use starlette TestClient for WebSocket tests ---\nfrom starlette.testclient import TestClient\n\n\n@pytest.fixture\ndef sync_client():\n    return TestClient(app)\n\n\ndef test_ws_invalid_role_closes_4000(sync_client):\n    with sync_client.websocket_connect(\"/ws/any-game/badrole\") as ws:\n        # Server should close with code 4000\n        data = ws.receive_json()  # may not arrive; check close code\n    # Starlette TestClient raises WebSocketDisconnect on close\n    # Adjust assertion to match your test framework behaviour\n\n\ndef test_ws_game_not_found_closes_4004(sync_client):\n    with sync_client.websocket_connect(\"/ws/no-such-game/retailer\") as ws:\n        pass  # expect close 4004\n\n\ndef test_ws_connect_sends_initial_state(sync_client, active_game_id):\n    with sync_client.websocket_connect(f\"/ws/{active_game_id}/retailer\") as ws:\n        msg = ws.receive_json()\n        assert msg[\"event\"] == \"connected\"\n        assert \"inventory\" in msg\n\n\ndef test_ws_order_action_accepted(sync_client, active_game_id):\n    with sync_client.websocket_connect(f\"/ws/{active_game_id}/retailer\") as ws:\n        ws.receive_json()  # consume connected event\n        ws.send_json({\"action\": \"order\", \"quantity\": 4})\n        msg = ws.receive_json()\n        assert msg[\"event\"] == \"order_accepted\"\n        assert msg[\"quantity\"] == 4\n\n\ndef test_ws_order_invalid_role_in_game_returns_error(sync_client, active_game_id):\n    # Role valid enum but already ordered twice — triggers ValueError\n    with sync_client.websocket_connect(f\"/ws/{active_game_id}/retailer\") as ws:\n        ws.receive_json()\n        ws.send_json({\"action\": \"order\", \"quantity\": 4})\n        ws.receive_json()  # order_accepted\n        ws.send_json({\"action\": \"order\", \"quantity\": 4})  # duplicate\n        msg = ws.receive_json()\n        assert msg[\"event\"] == \"error\"\n\n\ndef test_ws_get_state_action(sync_client, active_game_id):\n    with sync_client.websocket_connect(f\"/ws/{active_game_id}/retailer\") as ws:\n        ws.receive_json()\n        ws.send_json({\"action\": \"get_state\"})\n        msg = ws.receive_json()\n        assert msg[\"event\"] == \"state\"\n\n\ndef test_ws_round_complete_broadcast(sync_client, active_game_id):\n    \"\"\"All 4 roles ordering should trigger round_complete broadcast.\"\"\"\n    conns = {\n        role: sync_client.websocket_connect(f\"/ws/{active_game_id}/{role}\")\n        for role in [\"retailer\", \"wholesaler\", \"distributor\", \"factory\"]\n    }\n    opened = {role: ctx.__enter__() for role, ctx in conns.items()}\n    for ws in opened.values():\n        ws.receive_json()  # connected\n\n    for role, ws in opened.items():\n        ws.send_json({\"action\": \"order\", \"quantity\": 4})\n        ws.receive_json()  # order_accepted\n\n    # All connections should receive round_complete or game_over\n    for ws in opened.values():\n        msg = ws.receive_json()\n        assert msg[\"event\"] in (\"round_complete\", \"game_over\")\n\n    for role, ctx in conns.items():\n        ctx.__exit__(None, None, None)"
