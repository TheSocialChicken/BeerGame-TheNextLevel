        "content": "\ndef test_create_game_pipeline_prefill(engine):\n    cfg = GameConfig(shipping_delay=3, initial_inventory=12)\n    state = engine.create_game(cfg)\n    for ps in state.players.values():\n        assert len(ps.incoming_shipments) == 3\n        assert all(s.quantity == 6 for s in ps.incoming_shipments)\n\n\ndef test_create_game_id_is_uuid(engine):\n    import uuid\n    state = engine.create_game()\n    uuid.UUID(state.game_id)  # raises if not valid UUID\n\n\ndef test_create_game_unique_ids(engine):\n    s1 = engine.create_game()\n    s2 = engine.create_game()\n    assert s1.game_id != s2.game_id\n\n\ndef test_process_round_on_finished_raises(engine):\n    from core.ai_players.rule_based import ConstantOrderAI\n    cfg = GameConfig(num_rounds=1)\n    state = engine.create_game(cfg, ai_roles=set(PlayerRole))\n    state = engine.start_game(state)\n    for role in PlayerRole:\n        state = engine.submit_order(state, role, ConstantOrderAI(role).decide_order(state))\n    state = engine.process_round(state)\n    assert state.phase == GamePhase.FINISHED\n    with pytest.raises(ValueError):\n        engine.process_round(state)\n\n\ndef test_submit_order_duplicate_role_overwrites(engine):\n    state = engine.create_game()\n    state = engine.start_game(state)\n    state = engine.submit_order(state, PlayerRole.RETAILER, 4)\n    state = engine.submit_order(state, PlayerRole.RETAILER, 9)\n    assert state.orders_this_round[PlayerRole.RETAILER] == 9\n\n\ndef test_get_visible_state_contains_incoming_shipments(engine, all_ai_game):\n    visible = engine.get_visible_state(all_ai_game, PlayerRole.RETAILER)\n    assert \"incoming_shipments\" in visible\n    assert isinstance(visible[\"incoming_shipments\"], list)\n```\n\n---\n\n",
