        "language": "python",
        "code": "import pytest\nfrom unittest.mock import AsyncMock, patch\nfrom backend.services.connection_manager import ConnectionManager\nfrom core.models import PlayerRole\n\n\n@pytest.fixture\ndef manager():\n    return ConnectionManager()\n\n\n@pytest.fixture\ndef mock_ws():\n    ws = AsyncMock()\n    return ws\n\n\nasync def test_connect_adds_connection(manager, mock_ws):\n    await manager.connect(mock_ws, \"game1\", PlayerRole.RETAILER)\n    assert \"retailer\" in manager._connections[\"game1\"]\n    mock_ws.accept.assert_awaited_once()\n\n\nasync def test_disconnect_removes_role(manager, mock_ws):\n    await manager.connect(mock_ws, \"game1\", PlayerRole.RETAILER)\n    await manager.disconnect(\"game1\", PlayerRole.RETAILER)\n    assert \"game1\" not in manager._connections\n\n\nasync def test_disconnect_leaves_other_roles(manager, mock_ws):\n    ws2 = AsyncMock()\n    await manager.connect(mock_ws, \"game1\", PlayerRole.RETAILER)\n    await manager.connect(ws2, \"game1\", PlayerRole.WHOLESALER)\n    await manager.disconnect(\"game1\", PlayerRole.RETAILER)\n    assert \"wholesaler\" in manager._connections[\"game1\"]\n    assert \"retailer\" not in manager._connections[\"game1\"]\n\n\nasync def test_disconnect_nonexistent_is_noop(manager):\n    await manager.disconnect(\"no-such-game\", PlayerRole.RETAILER)\n\n\nasync def test_send_to_known_role(manager, mock_ws):\n    await manager.connect(mock_ws, \"game1\", PlayerRole.RETAILER)\n    await manager.send_to(\"game1\", PlayerRole.RETAILER, {\"msg\": \"hi\"})\n    mock_ws.send_text.assert_awaited_once()\n\n\nasync def test_send_to_unknown_role_is_noop(manager):\n    # Should not raise\n    await manager.send_to(\"game1\", PlayerRole.RETAILER, {\"msg\": \"hi\"})\n\n\nasync def test_broadcast_reaches_all_connections(manager):\n    ws1, ws2 = AsyncMock(), AsyncMock()\n    await manager.connect(ws1, \"game1\", PlayerRole.RETAILER)\n    await manager.connect(ws2, \"game1\", PlayerRole.WHOLESALER)\n    await manager.broadcast(\"game1\", {\"event\": \"test\"})\n    ws1.send_text.assert_awaited_once()\n    ws2.send_text.assert_awaited_once()\n\n\nasync def test_broadcast_prunes_dead_connections(manager):\n    ws = AsyncMock()\n    ws.send_text.side_effect = Exception(\"connection closed\")\n    await manager.connect(ws, \"game1\", PlayerRole.RETAILER)\n    await manager.broadcast(\"game1\", {\"event\": \"test\"})\n    # Dead connection pruned\n    assert \"retailer\" not in manager._connections.get(\"game1\", {})\n\n\nasync def test_connected_roles_empty(manager):\n    assert manager.connected_roles(\"no-such-game\") == []\n\n\nasync def test_connected_roles_lists_all(manager, mock_ws):\n    ws2 = AsyncMock()\n    await manager.connect(mock_ws, \"game1\", PlayerRole.RETAILER)\n    await manager.connect(ws2, \"game1\", PlayerRole.WHOLESALER)\n    roles = manager.connected_roles(\"game1\")\n    assert set(roles) == {\"retailer\", \"wholesaler\"}"
